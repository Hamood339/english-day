# Copy this file to .env and fill in real values. Never commit .env.

# Neon Postgres connection string (from your Neon project dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require

# Long random string used to sign login sessions
JWT_SECRET=replace-with-a-long-random-string

# Where the frontend runs (for CORS) and where the API runs
CLIENT_ORIGIN=http://localhost:5173
PORT=3001

# Frontend: base URL of the API (leave empty if using the Vite dev proxy)
VITE_API_URL=

# Initial admin account created by `npm run seed` (viewing is public, no account needed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Must match the CRON_SECRET env var set on Vercel — protects the daily
# auto-close endpoint so only Vercel Cron can trigger it
CRON_SECRET=replace-with-a-long-random-string
